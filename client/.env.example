# Backend RGS HTTP base URL (REQUIRED)
VITE_API_BASE_URL=http://localhost:8080

# Default gameId for /init (REQUIRED)
VITE_DEFAULT_GAME_ID=aztec-fire

# Default currency: EUR or USD (REQUIRED)
VITE_DEFAULT_CURRENCY=EUR

# Comma-separated bet ladder (optional)
VITE_BET_LADDER=0.20,0.50,1.00,2.00,5.00,10.00

# Demo dev-token panel (optional)
VITE_ENABLE_DEV_TOKEN=false

# Run with MSW network mocks (optional)
VITE_ENABLE_MSW=false

# Collapsible debug HUD (optional)
VITE_ENABLE_DEBUG_HUD=false

# JWT storage: 'memory' or 'session' (NEVER localStorage) (optional, default: memory)
VITE_AUTH_STORAGE=memory

# Remote log sink URL (optional)
# VITE_LOG_SINK_URL=

# Wallet balance refetch interval in ms (optional)
VITE_WALLET_REFRESH_MS=30000
